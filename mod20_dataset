"""
MOD20 / aerial-video dataset loader.

Improvements over the original:
  * Real bounding-box loading from an optional JSON annotation file.
  * Full augmentation pipeline: random spatial crop, horizontal flip,
    temporal jittering (+/- jitter frames around uniform sample points),
    and Gaussian blur. All spatial transforms are applied consistently
    to the bounding boxes.
  * Heatmap / offset / size targets are built AFTER the augmentations,
    so the supervision is always aligned with the augmented frames.
"""

import os
import json
import torch
from torch.utils.data import Dataset
import numpy as np
import cv2

try:
    import decord
    from decord import VideoReader, cpu
except ImportError:
    decord = None
    print("Warning: 'decord' not found. Install it: pip install decord")


VIDEO_EXTS = ('.mp4', '.avi', '.mov', '.mkv')


class MOD20Dataset(Dataset):
    """
    Aerial-video dataset loader.

    Folder structure (one folder per class):
        data_root/
            class_a/ video001.mp4 video002.mp4 ...
            class_b/ video010.mp4 ...

    Optional bounding-box annotations file at:
        data_root/annotations.json
    Format:
        {
            "<class_folder>/<video_filename>": [
                [cls_id, x, y, w, h],   # absolute pixel coords in the
                ...                     # original (un-resized) frame
            ],
            ...
        }
    Boxes are interpreted as constant across all frames of the clip
    (a reasonable simplification for short aerial action clips).
    Videos with no entry in annotations.json simply contribute zero
    detection supervision (the mask is all zeros, so the offset/size
    L1 losses are not affected by them).
    """

    def __init__(self,
                 data_root,
                 split='train',
                 num_frames=8,
                 spatial_size=(256, 256),
                 augment=True,
                 crop_scale=0.8,
                 flip_prob=0.5,
                 blur_prob=0.5,
                 temporal_jitter=2,
                 downsample_ratio=8,
                 det_classes=10):
        self.data_root        = data_root
        self.split            = split
        self.num_frames       = num_frames
        self.spatial_size     = spatial_size
        self.augment          = augment
        self.crop_scale       = float(crop_scale)
        self.flip_prob        = float(flip_prob)
        self.blur_prob        = float(blur_prob)
        self.temporal_jitter  = int(temporal_jitter)
        self.downsample_ratio = int(downsample_ratio)
        self.det_classes      = int(det_classes)

        self.video_paths      = []
        self.event_labels     = []
        self.bbox_annotations = []
        self.classes          = []
        self.class_to_idx     = {}

        self._load_annotations()

    # ------------------------------------------------------------------ #
    def _load_annotations(self):
        if not os.path.exists(self.data_root):
            print(f"[Warning] data_root not found: '{self.data_root}'")
            return

        bbox_file = os.path.join(self.data_root, 'annotations.json')
        bbox_db = {}
        if os.path.isfile(bbox_file):
            try:
                with open(bbox_file, 'r') as f:
                    bbox_db = json.load(f)
                print(f"Loaded bbox annotations for {len(bbox_db)} videos "
                      f"from {bbox_file}")
            except Exception as e:
                print(f"[Warning] failed to read {bbox_file}: {e}")
                bbox_db = {}

        classes = sorted(d for d in os.listdir(self.data_root)
                         if os.path.isdir(os.path.join(self.data_root, d)))
        if not classes:
            print(f"[Warning] No class subfolders in '{self.data_root}'")
            return

        self.classes = classes
        self.class_to_idx = {c: i for i, c in enumerate(classes)}
        print(f"Found {len(classes)} classes: {classes}")

        for cls_name in classes:
            cls_dir = os.path.join(self.data_root, cls_name)
            cls_id  = self.class_to_idx[cls_name]
            for vid_name in sorted(os.listdir(cls_dir)):
                if not vid_name.lower().endswith(VIDEO_EXTS):
                    continue
                full_path = os.path.join(cls_dir, vid_name)
                rel_key   = f"{cls_name}/{vid_name}"
                self.video_paths.append(full_path)
                self.event_labels.append(cls_id)
                self.bbox_annotations.append(bbox_db.get(rel_key, []))

        n_with_boxes = sum(1 for b in self.bbox_annotations if len(b) > 0)
        print(f"[{self.split}] {len(self.video_paths)} videos, "
              f"{n_with_boxes} with bbox annotations.")

    # ------------------------------------------------------------------ #
    def _sample_indices(self, total):
        """Uniform sampling with optional +/- jitter per sample."""
        n = self.num_frames
        if total <= 0:
            return np.zeros(n, dtype=np.int64)
        if total <= n:
            base = np.arange(total)
            pad  = np.full(n - total, total - 1, dtype=np.int64)
            return np.concatenate([base, pad])

        anchors = np.linspace(0, total - 1, n).astype(np.int64)
        if self.augment and self.temporal_jitter > 0:
            jit = np.random.randint(-self.temporal_jitter,
                                    self.temporal_jitter + 1, size=n)
            anchors = np.clip(anchors + jit, 0, total - 1)
            anchors = np.sort(anchors)
        return anchors

    def _load_frames(self, vid_path):
        if decord is not None:
            try:
                vr = VideoReader(vid_path, ctx=cpu(0))
                total   = len(vr)
                indices = self._sample_indices(total)
                frames  = vr.get_batch(indices).asnumpy()
                return list(frames)
            except Exception as e:
                print(f"[Warning] decord failed for {vid_path}: {e}. "
                      f"Falling back to OpenCV.")

        cap   = cv2.VideoCapture(vid_path)
        total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        indices = self._sample_indices(total) if total > 0 else \
                  np.zeros(self.num_frames, dtype=np.int64)
        frames = []
        for fi in indices:
            cap.set(cv2.CAP_PROP_POS_FRAMES, int(fi))
            ret, frame = cap.read()
            if ret:
                frames.append(cv2.cvtColor(frame, cv2.COLOR_BGR2RGB))
        cap.release()
        while len(frames) < self.num_frames:
            if frames:
                frames.append(frames[-1])
            else:
                frames.append(np.zeros((self.spatial_size[0],
                                        self.spatial_size[1], 3),
                                       dtype=np.uint8))
        return frames

    # ------------------------------------------------------------------ #
    def _augment_frames_and_boxes(self, frames, bboxes):
        """Apply spatial augmentations consistently to frames and boxes."""
        H_in, W_in = frames[0].shape[:2]
        boxes = [list(b) for b in bboxes]

        # 1. Random spatial crop
        if self.augment and self.crop_scale < 1.0:
            scale = np.random.uniform(self.crop_scale, 1.0)
            ch = max(1, int(round(H_in * scale)))
            cw = max(1, int(round(W_in * scale)))
            y0 = np.random.randint(0, H_in - ch + 1)
            x0 = np.random.randint(0, W_in - cw + 1)
            frames = [f[y0:y0 + ch, x0:x0 + cw] for f in frames]
            new_boxes = []
            for cls, x, y, w, h in boxes:
                x1 = max(x, x0); y1 = max(y, y0)
                x2 = min(x + w, x0 + cw); y2 = min(y + h, y0 + ch)
                if x2 - x1 > 1 and y2 - y1 > 1:
                    new_boxes.append([cls, x1 - x0, y1 - y0,
                                      x2 - x1, y2 - y1])
            boxes = new_boxes
            H_cur, W_cur = ch, cw
        else:
            H_cur, W_cur = H_in, W_in

        # 2. Horizontal flip
        if self.augment and np.random.rand() < self.flip_prob:
            frames = [f[:, ::-1].copy() for f in frames]
            boxes = [[cls, W_cur - (x + w), y, w, h]
                     for cls, x, y, w, h in boxes]

        # 3. Gaussian blur (vibration proxy)
        if self.augment and np.random.rand() < self.blur_prob:
            frames = [cv2.GaussianBlur(f, (5, 5), 0) for f in frames]

        # 4. Resize to network input size
        H_out, W_out = self.spatial_size
        sx = W_out / float(W_cur)
        sy = H_out / float(H_cur)
        frames = [cv2.resize(f, (W_out, H_out)) for f in frames]
        boxes  = [[cls, x * sx, y * sy, w * sx, h * sy]
                  for cls, x, y, w, h in boxes]
        return frames, boxes

    # ------------------------------------------------------------------ #
    def _build_spatial_targets(self, bboxes):
        ds     = self.downsample_ratio
        feat_h = self.spatial_size[0] // ds
        feat_w = self.spatial_size[1] // ds

        heatmap = np.zeros((self.det_classes, feat_h, feat_w), dtype=np.float32)
        offset  = np.zeros((2, feat_h, feat_w),                dtype=np.float32)
        size    = np.zeros((2, feat_h, feat_w),                dtype=np.float32)
        mask    = np.zeros((feat_h, feat_w),                   dtype=np.float32)

        for box in bboxes:
            cls_id, x, y, w, h = box
            cls_id = int(cls_id)
            if cls_id < 0 or cls_id >= self.det_classes:
                continue
            cx = (x + w / 2.0) / ds
            cy = (y + h / 2.0) / ds
            cx_i, cy_i = int(cx), int(cy)
            if 0 <= cx_i < feat_w and 0 <= cy_i < feat_h:
                radius = max(1, int(min(w, h) / ds / 4))
                self._draw_gaussian(heatmap[cls_id], (cx_i, cy_i), radius)
                offset[0, cy_i, cx_i] = cx - cx_i
                offset[1, cy_i, cx_i] = cy - cy_i
                size[0, cy_i, cx_i]   = w / ds
                size[1, cy_i, cx_i]   = h / ds
                mask[cy_i, cx_i]      = 1.0
        return heatmap, offset, size, mask

    @staticmethod
    def _draw_gaussian(hm, center, radius, k=1):
        diameter = 2 * radius + 1
        sigma    = diameter / 6.0
        x_axis   = np.arange(diameter) - radius
        gauss    = np.exp(-(x_axis[:, None] ** 2 + x_axis[None, :] ** 2)
                          / (2 * sigma ** 2))
        gauss[gauss < np.finfo(gauss.dtype).eps * gauss.max()] = 0

        cx, cy = center
        h, w = hm.shape
        left   = min(cx, radius); right = min(w - cx, radius + 1)
        top    = min(cy, radius); bottom = min(h - cy, radius + 1)
        masked_hm    = hm[cy - top:cy + bottom, cx - left:cx + right]
        masked_gauss = gauss[radius - top:radius + bottom,
                             radius - left:radius + right]
        if masked_hm.size > 0 and masked_gauss.size > 0:
            np.maximum(masked_hm, masked_gauss * k, out=masked_hm)

    # ------------------------------------------------------------------ #
    def __len__(self):
        return len(self.video_paths)

    def __getitem__(self, idx):
        vid_path  = self.video_paths[idx]
        event_cls = self.event_labels[idx]
        bboxes    = self.bbox_annotations[idx]

        frames = self._load_frames(vid_path)
        frames, boxes_aug = self._augment_frames_and_boxes(frames, bboxes)

        frames_np     = np.stack(frames, axis=0).transpose(3, 0, 1, 2)
        frames_np     = frames_np.astype(np.float32) / 255.0
        frames_tensor = torch.from_numpy(frames_np)

        hm, off, sz, mask = self._build_spatial_targets(boxes_aug)

        return (
            frames_tensor,
            torch.tensor(event_cls, dtype=torch.long),
            torch.from_numpy(hm),
            torch.from_numpy(off),
            torch.from_numpy(sz),
            torch.from_numpy(mask),
        )
